{
  "redirects": [
    {
      "source": "/catalogue",
      "destination": "/assets/downloads/Catalogue Aplati Final.pdf",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/downloads/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "application/pdf"
        }
      ]
    }
  ],
  "version": "2026-04-06-final"
}